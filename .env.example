# keepIT — environment variables (example)
#
# Copy to `.env` for Docker Compose. Anything set here OVERRIDES appsettings.json;
# anything left unset FALLS BACK to the values in appsettings.json.
# ASP.NET Core maps "__" (double underscore) to config section nesting, so
# Jwt__Issuer  ==  the "Jwt": { "Issuer": ... } setting.

# ---- Runtime ----
ASPNETCORE_ENVIRONMENT=Production

# ---- JWT ----
# REQUIRED in production: a long random secret (>= 32 chars). Never commit the real one.
Jwt__Key=
# Optional — fall back to appsettings.json ("keepITCore" / "keepIT.api") if unset.
Jwt__Issuer=keepITCore
Jwt__Audience=keepIT.api
# Jwt__AccessTokenMinutes=15
# Jwt__RefreshTokenDays=14

# ---- Database ----
# If a Postgres connection is set, the API uses Postgres; otherwise it falls back to SQLite.
# Either give a full connection string...
ConnectionStrings__Postgres=Host=db;Port=5432;Database=keepit;Username=keepit;Password=change-me
# ...or the discrete parts (used only if ConnectionStrings__Postgres is empty):
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# POSTGRES_DB=keepit
# POSTGRES_USER=keepit
# POSTGRES_PASSWORD=change-me

# ---- Data folder (SQLite db, media, keys) ----
# App__DataRoot=/app/App_Data

# ---- Refresh-token cookie ----
# Keep true in production (https). Set false only for local plain-http dev.
Auth__RefreshCookie__Secure=true

# ---- CORS (frontend origin; array indices are 0-based) ----
Cors__AllowedOrigins__0=https://app.keepit.example

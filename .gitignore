# ---- keepIT ----

# Common data folder (App__DataRoot): SQLite dev DB, uploaded media, data-protection keys.
# Named App_Data (not "data") so it never collides with the C# Data/ source folder on
# case-insensitive filesystems. Never commit user data.
App_Data/
**/App_Data/
*.db
*.db-shm
*.db-wal

# User-uploaded media (image notes + background images). Never commit user data.
media/
**/media/

# ---- .NET / ASP.NET Core ----
bin/
obj/
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
*.user
*.userosscache
*.suo
*.cache

# Build / publish output
[Pp]ublish/
artifacts/

# Local app secrets & environment
appsettings.*.local.json
*.env
.env
.env.*
!.env.example
secrets.json

# ---- Visual Studio / Rider / VS Code ----
.vs/
.vscode/
.idea/
*.swp

# ---- Node / React frontend (web/) ----
node_modules/
dist/
dist-ssr/
.vite/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- OS ----
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ---- Docker ----
# (compose env overrides, if any)
docker-compose.override.yml

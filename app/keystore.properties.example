# Release signing credentials for local signed builds.
#
# Copy this file to `keystore.properties` (gitignored) and fill in your real values, OR leave it
# absent — CI supplies the same values via env vars (KEYSTORE_PATH, KEYSTORE_PASSWORD, KEY_ALIAS,
# KEY_PASSWORD). With neither, `assembleRelease` produces an UNSIGNED apk.
#
# Generate the keystore once and keep it OUTSIDE the repo (back it up: password manager + offline):
#   keytool -genkeypair -v -keystore keepit-release.jks -alias keepit \
#     -keyalg RSA -keysize 4096 -validity 10000

storeFile=/absolute/path/to/keepit-release.jks
storePassword=changeme
keyAlias=keepit
keyPassword=changeme

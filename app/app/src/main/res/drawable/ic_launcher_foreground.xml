<!--
  keepIT launcher foreground — the logo mark from docs/logo.svg (the little "keep" basket), drawn as
  stroked paths in the brand accent (#fbbf24). The original artwork is authored in a 40-unit box with
  an inner translate(8,8); the outer group scales it (×3.6) and recenters it into the 108-unit
  adaptive-icon canvas so the mark sits inside the 72-unit safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="3.6"
        android:scaleY="3.6"
        android:translateX="-18"
        android:translateY="-14.4">
        <group
            android:translateX="8"
            android:translateY="8">
            <!-- lid handle -->
            <path
                android:pathData="M9,3 h6 v3 H9 z"
                android:fillColor="#00000000"
                android:strokeColor="#FBBF24"
                android:strokeWidth="1.8"
                android:strokeLineCap="round"
                android:strokeLineJoin="round" />
            <!-- lid (rounded bar) -->
            <path
                android:pathData="M4.5,6 L19.5,6 A1.5,1.5 0 0 1 21,7.5 A1.5,1.5 0 0 1 19.5,9 L4.5,9 A1.5,1.5 0 0 1 3,7.5 A1.5,1.5 0 0 1 4.5,6 Z"
                android:fillColor="#00000000"
                android:strokeColor="#FBBF24"
                android:strokeWidth="1.8"
                android:strokeLineCap="round"
                android:strokeLineJoin="round" />
            <!-- lid pins -->
            <path
                android:pathData="M7,9 v2"
                android:fillColor="#00000000"
                android:strokeColor="#FBBF24"
                android:strokeWidth="1.8"
                android:strokeLineCap="round"
                android:strokeLineJoin="round" />
            <path
                android:pathData="M17,9 v2"
                android:fillColor="#00000000"
                android:strokeColor="#FBBF24"
                android:strokeWidth="1.8"
                android:strokeLineCap="round"
                android:strokeLineJoin="round" />
            <!-- basket body -->
            <path
                android:pathData="M6,11 h12 l2.5,8 H3.5 z"
                android:fillColor="#00000000"
                android:strokeColor="#FBBF24"
                android:strokeWidth="1.8"
                android:strokeLineCap="round"
                android:strokeLineJoin="round" />
            <!-- slot -->
            <path
                android:pathData="M8,16 h8"
                android:fillColor="#00000000"
                android:strokeColor="#FBBF24"
                android:strokeWidth="1.8"
                android:strokeLineCap="round"
                android:strokeLineJoin="round" />
        </group>
    </group>
</vector>
